generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(cuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  parentId  String?
  parent    Page?    @relation("PageTree", fields: [parentId], references: [id])
  children  Page[]   @relation("PageTree")
  title     String
  order     Int      @default(0)
  isVisible Boolean  @default(true)
  isHome    Boolean  @default(false)
  sections  Section[]
  seo       SeoSettings?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model Section {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  slug      String
  order     Int
  isVisible Boolean  @default(true)
  titlePl   String?
  titleEn   String?
  contentPl Json
  contentEn Json
  bgImage   String?
  bgColor   String?
  tags      String    @default("[]")
  galleryImages GalleryImage[]
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([pageId, slug])
}

model Reservation {
  id         String            @id @default(cuid())
  guestName  String
  guestEmail String
  guestPhone String?
  checkIn    DateTime
  checkOut   DateTime
  guests     Int
  nights     Int
  totalPrice Float
  comment    String?
  status     ReservationStatus @default(PENDING)
  adminNote  String?
  isPaid     Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([checkIn, checkOut])
  @@index([status])
}

enum ReservationStatus {
  PENDING
  DEPOSIT_PAID
  PAID
  CANCELLED
  COMPLETED
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([date])
}

model GalleryImage {
  id          String   @id @default(cuid())
  sectionId   String?
  section     Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  originalUrl String
  webpUrl     String
  thumbUrl    String?
  altPl       String?
  altEn       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SeoSettings {
  id             String  @id @default(cuid())
  pageId         String  @unique
  page           Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  titlePl        String?
  titleEn        String?
  descriptionPl  String?
  descriptionEn  String?
  ogImageUrl     String?
  customHeadTags String?
}

model SiteSettings {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}
